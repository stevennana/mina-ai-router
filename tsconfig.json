{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["apps/http-server/ui"]
}
